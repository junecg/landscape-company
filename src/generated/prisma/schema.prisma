generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  titleEn       String
  category      String
  location      String
  area          String   @default("—")
  duration      String   @default("—")
  client        String
  year          String
  image         String
  images        String[]
  description   String   @db.Text
  descriptionEn String   @db.Text
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
  @@index([published])
  @@map("project")
}

model Service {
  id         String   @id @default(cuid())
  slug       String   @unique
  order      Int      @default(0)
  icon       String
  titleVi    String
  titleEn    String
  subtitleVi String
  subtitleEn String
  descVi     String   @db.Text
  descEn     String   @db.Text
  tag        String
  bulletsVi  String[]
  bulletsEn  String[]
  images     String[]
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([published])
  @@map("service")
}

model NewsArticle {
  id         String   @id @default(cuid())
  slug       String   @unique
  titleVi    String
  titleEn    String
  summaryVi  String   @db.Text
  summaryEn  String   @db.Text
  contentVi  String   @default("") @db.Text
  contentEn  String   @default("") @db.Text
  image      String
  categoryVi String
  categoryEn String
  date       String
  readTime   Int      @default(4)
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([published])
  @@index([categoryVi])
  @@map("news_article")
}

model Partner {
  id          String   @id @default(cuid())
  order       Int      @default(0)
  name        String
  sectorVi    String
  sectorEn    String
  descVi      String   @db.Text
  descEn      String   @db.Text
  founded     Int
  hq          String
  statLabelVi String
  statLabelEn String
  statValue   String
  projectsVi  String[]
  projectsEn  String[]
  highlightVi String   @db.Text
  highlightEn String   @db.Text
  images      String[]
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published])
  @@map("partner")
}

model TimelineItem {
  id        String   @id @default(cuid())
  order     Int      @default(0)
  year      String
  titleVi   String
  titleEn   String
  descVi    String   @db.Text
  descEn    String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("timeline_item")
}

model Media {
  id        String   @id @default(cuid())
  url       String
  filename  String   @default("")
  folder    String   @default("gallery")
  createdAt DateTime @default(now())

  @@map("media")
}

model MemberCompany {
  id        String   @id @default(cuid())
  order     Int      @default(0)
  abbr      String
  name      String
  tagline   String
  descVi    String
  descEn    String
  accent    String
  images    String[]
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published])
  @@map("member_company")
}
